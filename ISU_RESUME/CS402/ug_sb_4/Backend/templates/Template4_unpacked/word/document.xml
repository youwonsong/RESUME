<w:p w14:paraId="0A000001" w14:textId="77777777" w:rsidR="00D2605A" w:rsidRDefault="00D2605A" w:rsidP="00D2605A"><w:pPr><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">{{ pi_name }}, Principal Investigator, {{ pi_months }} calendar months each year of project. The PI will lead the project and be responsible for research activities, data interpretation, and preparation of publications and project reports. PI will devote effort to this project commensurate with the requested salary support.</w:t></w:r></w:p>
<w:p w14:paraId="0A000002" w14:textId="77777777" w:rsidR="00D2605A" w:rsidRDefault="00D2605A" w:rsidP="00D2605A"><w:pPr><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">{%p for p in key_personnel[1:] %}</w:t></w:r></w:p>
