<w:p w14:paraId="0A000004" w14:textId="77777777" w:rsidR="00D2605A" w:rsidRDefault="00D2605A" w:rsidP="00D2605A"><w:pPr><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:cs="Arial"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">{%p endfor %}</w:t></w:r></w:p>
