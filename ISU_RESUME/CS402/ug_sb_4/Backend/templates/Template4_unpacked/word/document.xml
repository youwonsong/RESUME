<w:p w14:paraId="0A000022" w14:textId="77777777" w:rsidR="00D2605A" w:rsidRDefault="00D2605A" w:rsidP="00AC7BDF"><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">8. Other Direct Costs</w:t></w:r></w:p>
